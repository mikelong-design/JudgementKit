---
import { render } from 'astro:content';

import SiteLayout from '../../../components/SiteLayout.astro';
import PageSubnav from '../../../components/PageSubnav.astro';
import { IA_LABELS, ROUTES } from '../../../lib/ia';
import {
  getContractsForWorkflow,
  getContractsSiteData,
  getPlaybookBySlug,
  getTestsForWorkflow,
  getWorkflowBySlug
} from '../../../lib/contracts';

export async function getStaticPaths() {
  const { workflows } = await getContractsSiteData();

  return workflows.map((workflow) => ({
    params: { workflowSlug: workflow.slug }
  }));
}

const { contracts, driftTests, workflows, playbooks } = await getContractsSiteData();
const workflow = getWorkflowBySlug(workflows, Astro.params.workflowSlug || '');

if (!workflow) {
  throw new Error(`Unknown workflow slug: ${Astro.params.workflowSlug}`);
}

const { Content } = await render(workflow);
const relatedContracts = getContractsForWorkflow(workflow, contracts);
const relatedTests = getTestsForWorkflow(workflow, driftTests);
const playbook = getPlaybookBySlug(playbooks, workflow.data.playbookSlug);
const provenanceContract = relatedContracts.find((contract) => contract.data.id === 'JK-CONTRACT-005');
const sectionLinks = [
  { href: '#steps', label: 'Operating flow' },
  { href: '#record', label: 'Decision record' },
  { href: '#coverage', label: 'Coverage' },
  { href: '#context', label: 'Context' }
];

if (!playbook) {
  throw new Error(`Workflow ${workflow.slug} is missing its playbook.`);
}

const flowSteps = [
  {
    title: 'Record',
    body: 'Capture a stable decision record before the output leaves draft status.'
  },
  {
    title: 'Evaluate',
    body: 'Run contract-specific drift tests against copy, structure, runtime, and provenance.'
  },
  {
    title: 'Respond',
    body: 'Map pass, warn, or fail states to allow, nudge, correct, quarantine, or escalate.'
  },
  {
    title: 'Revise',
    body: 'Use incidents and near misses to update thresholds, rules, and ownership boundaries.'
  }
];
---

<SiteLayout
  title={workflow.data.title}
  description={workflow.data.summary}
  path={`/contracts/workflows/${workflow.slug}`}
  bodyClass="contracts-page contract-workflow-page"
>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href={ROUTES.home}>{IA_LABELS.home}</a></li>
      <li><a href={ROUTES.resources}>{IA_LABELS.resources}</a></li>
      <li><a href={ROUTES.workflowGovernance}>{IA_LABELS.workflowGovernance}</a></li>
      <li aria-current="page">{workflow.data.title}</li>
    </ol>
  </nav>

  <section class="platform-hero" aria-labelledby="workflow-title">
    <div class="hero-copy">
      <span class="muted-chip">Workflow</span>
      <h1 id="workflow-title">{workflow.data.title}</h1>
      <p class="subhead">{workflow.data.summary}</p>
      <p>
        This workflow is the first fully modeled JudgmentKit pilot because it turns the Design
        Judgment Kit thesis into an operational review loop that teams can inspect before publish.
      </p>
      <div class="cta-row">
        <a class="button primary" href={`/contracts/playbooks/${playbook.slug}`}>Read playbook</a>
        <a class="button ghost" href={ROUTES.resources}>Back to resources</a>
      </div>
    </div>

    <aside class="module-sidecard" aria-label="Workflow context">
      <strong>Default surface</strong>
      <p>{workflow.data.defaultSurface}</p>

      <strong>Default audience</strong>
      <p>{workflow.data.defaultAudience}</p>

      <strong>Related kit</strong>
      <p><a href={ROUTES.designKit}>Design Judgment Kit</a></p>

      <strong>Back to resources</strong>
      <p><a href={ROUTES.workflowGovernance}>Browse workflow governance</a></p>
    </aside>
  </section>

  <PageSubnav links={sectionLinks} />

  <section id="steps" aria-labelledby="steps-title">
    <span class="eyebrow">Operating flow</span>
    <h2 id="steps-title">How a governed workflow runs</h2>
    <div class="module-nav-grid">
      {
        flowSteps.map((step) => (
          <article class="module-nav-card">
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </article>
        ))
      }
    </div>
  </section>

  <section id="record" aria-labelledby="record-title">
    <span class="eyebrow">Decision record</span>
    <h2 id="record-title">Required fields for governed AI workflow decisions</h2>
    <div class="module-columns">
      <div class="module-section">
        <p>
          These fields form the minimum audit trail needed to make consequential AI outputs
          attributable and reviewable before they leave draft status.
        </p>
        <ul class="support-list" aria-describedby="record-title">
          {
            workflow.data.decisionRecordFields.map((field) => (
              <li><code>{field}</code></li>
            ))
          }
        </ul>
      </div>

      <aside class="module-sidecard" aria-label="Decision record rationale">
        <strong>Why this checklist exists</strong>
        <p>
          The deeper rationale lives in the provenance contract, which defines the accountable
          trace required for consequential workflow actions.
        </p>
        {
          provenanceContract ? (
            <p>
              <a href={`/contracts/${provenanceContract.slug}`}>
                Read {provenanceContract.data.name}
              </a>
            </p>
          ) : null
        }
      </aside>
    </div>
  </section>

  <section id="coverage" aria-labelledby="coverage-title">
    <span class="eyebrow">Coverage</span>
    <h2 id="coverage-title">Related contracts and drift tests</h2>
    <div class="module-columns">
      <div class="module-section">
        <span class="eyebrow">Contracts</span>
        <div class="module-nav-grid">
          {
            relatedContracts.map((contract) => (
              <article class="module-nav-card">
                <span class="muted-chip">{contract.data.id}</span>
                <h3>{contract.data.name}</h3>
                <p>{contract.data.intent}</p>
                <a href={`/contracts/${contract.slug}`}>Read contract</a>
              </article>
            ))
          }
        </div>
      </div>

      <div class="module-section">
        <span class="eyebrow">Drift tests</span>
        <div class="module-nav-grid">
          {
            relatedTests.map((test) => (
              <article class="module-nav-card">
                <span class="muted-chip">{test.data.id}</span>
                <h3>{test.data.name}</h3>
                <p>{test.data.purpose}</p>
                <a href={`/contracts/tests/${test.slug}`}>Read drift test</a>
              </article>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <section id="context" aria-labelledby="context-title">
    <span class="eyebrow">Context</span>
    <h2 id="context-title">Why this workflow is the first pilot</h2>
    <div class="content-stack">
      <Content />
    </div>
  </section>
</SiteLayout>
