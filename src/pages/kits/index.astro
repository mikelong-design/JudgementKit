---
import SiteLayout from '../../components/SiteLayout.astro';
import PageSubnav from '../../components/PageSubnav.astro';
import { getAllKits, orderedModules } from '../../lib/kits';

const kits = getAllKits();
const sectionLinks = [{ href: '#current-kits', label: 'Current kits' }];
---

<SiteLayout
  title="Kits"
  description="Browse JudgmentKit operating kits and their practical modules."
  path="/kits"
  bodyClass="kits-index"
>
  <section aria-labelledby="kits-index-title">
    <span class="eyebrow">Operating kits</span>
    <h1 id="kits-index-title">Start with an operating kit before you reach for governance detail.</h1>
    <p class="subhead">
      Kits are the primary JudgmentKit entry point. Each one packages practical modules, a short
      runbook, and reusable references teams can use in live product decisions.
    </p>
  </section>

  <PageSubnav links={sectionLinks} />

  <section id="current-kits" aria-labelledby="library-title">
    <span class="eyebrow">Current kits</span>
    <h2 id="library-title">Current operating kits</h2>
    <div class="current-kits-grid">
      {
        kits.map((kit) => {
          const modules = orderedModules(kit);

          return (
            <article class="kit-card">
              <span class="muted-chip">{kit.audience}</span>
              <h3>{kit.title}</h3>
              <p>{kit.subtitle}</p>
              <p>{kit.summary}</p>
              <div class="resource-meta">
                <span class="resource-kicker">Included modules</span>
                <ul class="support-list">
                  {modules.map((module) => <li>{module.title}</li>)}
                </ul>
              </div>
              <div class="cta-row">
                <a class="button primary" href={`/kits/${kit.slug}`}>Start with this kit</a>
                <a class="button ghost" href={`/kits/${kit.slug}/${modules[0]?.slug}`}>
                  {modules[0]?.title ? `Read ${modules[0].title}` : 'Browse modules'}
                </a>
              </div>
            </article>
          );
        })
      }
    </div>
  </section>
</SiteLayout>
