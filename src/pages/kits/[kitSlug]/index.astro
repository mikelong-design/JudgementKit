---
import SiteLayout from '../../../components/SiteLayout.astro';
import PageSubnav from '../../../components/PageSubnav.astro';
import { IA_LABELS, ROUTES } from '../../../lib/ia';
import { getAllKits, getKitBySlug, orderedModules } from '../../../lib/kits';

export function getStaticPaths() {
  return getAllKits().map((kit) => ({
    params: { kitSlug: kit.slug }
  }));
}

const kit = getKitBySlug(Astro.params.kitSlug || '');

if (!kit) {
  throw new Error(`Unknown kit slug: ${Astro.params.kitSlug}`);
}

const modules = orderedModules(kit);
const framingPagePath = kit.slug === 'design-judgment' ? ROUTES.designLeadership : undefined;
const sectionLinks = [
  { href: '#modules', label: 'Modules' },
  { href: '#runbook', label: 'Runbook' },
  ...(framingPagePath ? [{ href: '#leadership-framing', label: IA_LABELS.leadershipFraming }] : []),
  ...(kit.slug === 'design-judgment'
    ? [{ href: '#related-resources', label: 'Related resources' }]
    : []),
  ...(kit.flowStages ? [{ href: '#flow', label: 'Flow' }] : [])
];

const relatedResources =
  kit.slug === 'design-judgment'
    ? [
        {
          title: 'AI UI Generation workflow',
          body: 'See how the same judgment model becomes explicit workflow governance before generated UI reaches publish risk.',
          href: ROUTES.pilotWorkflow,
          cta: 'Open workflow'
        },
        {
          title: 'Workflow governance library',
          body: 'Browse the contracts, drift tests, and governance resources that extend this kit into operational review.',
          href: ROUTES.workflowGovernance,
          cta: 'Browse workflow governance'
        },
        {
          title: 'Drift Response Playbook',
          body: 'Read the response policy that decides what happens after drift is measured.',
          href: '/contracts/playbooks/drift-response',
          cta: 'Read playbook'
        }
      ]
    : [];
---

<SiteLayout
  title={kit.title}
  description={kit.summary}
  path={`/kits/${kit.slug}`}
  bodyClass="kit-page"
>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <ol>
      <li><a href={ROUTES.home}>{IA_LABELS.home}</a></li>
      <li><a href={ROUTES.kits}>{IA_LABELS.kits}</a></li>
      <li aria-current="page">{kit.title}</li>
    </ol>
  </nav>

  <section class="platform-hero" aria-labelledby="kit-title">
    <div class="hero-copy">
      <span class="muted-chip">{kit.audience}</span>
      <h1 id="kit-title">{kit.title}</h1>
      <p class="subhead">{kit.subtitle}</p>
      <p>{kit.summary}</p>
      <p>
        <strong>Core thesis:</strong> {kit.coreThesis}
      </p>
      <div class="cta-row">
        <a class="button primary" href={`/kits/${kit.slug}/${modules[0]?.slug}`}>
          {modules[0]?.title ? `Start with ${modules[0].title}` : 'Start with this kit'}
        </a>
        <a class="button ghost" href={ROUTES.resources}>Browse all resources</a>
      </div>
    </div>

    <div class="hero-sidebar">
      <article class="summary-card">
        <strong>How this kit is used</strong>
        <p>Apply it to one active initiative where AI drafts are moving fast and decision ambiguity is rising.</p>
      </article>
      <article class="summary-card">
        <strong>What this protects</strong>
        <p>Decision quality, ownership, rationale capture, and system coherence before commitments lock in.</p>
      </article>
    </div>
  </section>

  <PageSubnav links={sectionLinks} />

  <section id="modules" aria-labelledby="modules-title">
    <span class="eyebrow">Modules</span>
    <h2 id="modules-title">Start with the concrete kit modules</h2>
    <div class="module-nav-grid">
      {
        modules.map((module) => (
          <article class="module-nav-card">
            <span class="muted-chip">{module.slug}</span>
            <h3>{module.title}</h3>
            <p>{module.summary}</p>
            <a href={`/kits/${kit.slug}/${module.slug}`}>Read {module.title}</a>
          </article>
        ))
      }
    </div>
  </section>

  <section id="runbook" aria-labelledby="how-title">
    <span class="eyebrow">Runbook</span>
    <h2 id="how-title">How to use this kit in live delivery work</h2>
    <div class="module-columns">
      <div class="module-section">
        <ol>
          {
            kit.howToUse.map((step) => (
              <li>{step}</li>
            ))
          }
        </ol>
      </div>
      <aside class="module-sidecard" aria-label="Common failure modes">
        <strong>Common failure modes</strong>
        <ul>
          {
            kit.failureModes.map((item) => (
              <li>{item}</li>
            ))
          }
        </ul>
      </aside>
    </div>
  </section>

  {framingPagePath && (
    <section id="leadership-framing" aria-labelledby="framing-title">
      <span class="eyebrow">{IA_LABELS.leadershipFraming}</span>
      <h2 id="framing-title">Recommended background reading for design leaders</h2>
      <div class="module-columns">
        <div class="module-section">
          <div class="module-copy">
            <p>
              Use the leadership-framing page when you need the design-leadership rationale behind
              this kit before moving into the working modules.
            </p>
            <p>
              It explains why ownership, decision rights, quality thresholds, and cadence have to
              become explicit earlier when AI makes drafts look finished before teams are aligned.
            </p>
          </div>
          <div class="cta-row">
            <a class="button primary" href={framingPagePath}>Read leadership framing</a>
            <a class="button ghost" href={`/kits/${kit.slug}/${modules[0]?.slug}`}>
              {modules[0]?.title ? `Start with ${modules[0].title}` : 'Start with this kit'}
            </a>
          </div>
        </div>

        <aside class="module-sidecard" aria-label="Leadership framing summary">
          <strong>What it adds</strong>
          <p>
            A role-specific explanation of how to use this kit as an operating mechanism, not just
            as a reference page.
          </p>
        </aside>
      </div>
    </section>
  )}

  {relatedResources.length > 0 && (
    <section id="related-resources" aria-labelledby="related-title">
      <span class="eyebrow">Related resources</span>
      <h2 id="related-title">Related workflow governance resources</h2>
      <div class="module-nav-grid">
        {relatedResources.map((resource) => (
          <article class="module-nav-card">
            <span class="muted-chip">Workflow governance</span>
            <h3>{resource.title}</h3>
            <p>{resource.body}</p>
            <a href={resource.href}>{resource.cta}</a>
          </article>
        ))}
      </div>
    </section>
  )}

  {kit.flowStages && (
    <section id="flow" class="flow-section" aria-labelledby="flow-title">
      <span class="eyebrow">Flow</span>
      <h2 id="flow-title">Stage-driven workflow</h2>
      <div class="flow-rail">
        {
          kit.flowStages.map((stage) => (
            <article class="flow-stage">
              <strong>{stage.stage}</strong>
              <p>{stage.purpose}</p>
            </article>
          ))
        }
      </div>
    </section>
  )}
</SiteLayout>
