---
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/inter/700.css';
import '@fontsource/instrument-serif/400.css';

import {
  failureModes,
  getMatrixRows,
  getRaciRows,
  heroSlides,
  howToUseSteps,
  kitModules
} from '../../lib/kit-content';
import '../../styles/kit-shared.css';
import '../../styles/layout-baseline.css';

const matrix = getMatrixRows();
const raci = getRaciRows();
const pageTitle = 'Design Judgment Kit - Baseline Layout';
const pageDescription =
  'Baseline kit-first layout with shared interactions and no style-guide section.';
const ogImage = '/assets/ownership_visible_v4_header_1536x804.png';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <meta name="robots" content="noindex,nofollow" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="layout-baseline">
    <a class="skip-link" href="#main-content">Skip to content</a>

    <header class="site-nav">
      <div class="nav-inner">
        <a class="brand" href="#overview">Design Judgment Kit</a>
        <button
          type="button"
          class="menu-toggle"
          aria-expanded="false"
          aria-controls="mobile-nav"
          data-menu-toggle
        >
          Menu
        </button>
        <nav class="nav-links" aria-label="Primary">
          <a href="/review">Review Hub</a>
          <a href="#overview">Overview</a>
          <a href="#kit-modules">Kit Modules</a>
          <a href="#matrix">Matrix</a>
          <a href="#decision-rights">Decision Rights</a>
          <a href="#how-to-use">How to Use</a>
          <a href="#downloads">Downloads</a>
        </nav>
      </div>
      <nav id="mobile-nav" class="mobile-menu" data-open="false" aria-label="Mobile sections">
        <a href="/review">Review Hub</a>
        <a href="#overview">Overview</a>
        <a href="#kit-modules">Kit Modules</a>
        <a href="#matrix">Matrix</a>
        <a href="#decision-rights">Decision Rights</a>
        <a href="#how-to-use">How to Use</a>
        <a href="#downloads">Downloads</a>
      </nav>
    </header>

    <main id="main-content" class="layout-shell">
      <section id="overview" aria-labelledby="overview-title">
        <div class="hero-wrap">
          <figure class="hero-media">
            <div class="hero-carousel" role="region" aria-label="Hero image comparison" tabindex="0" data-carousel>
              <div class="hero-carousel-track">
                {
                  heroSlides.map((slide, index) => (
                    <figure class="hero-slide" data-slide hidden={index !== 0} aria-hidden={index !== 0}>
                      <img
                        class="hero-banner"
                        src={slide.src}
                        alt={slide.alt}
                        width="1536"
                        height="804"
                        loading={index === 0 ? 'eager' : 'lazy'}
                        decoding="async"
                      />
                    </figure>
                  ))
                }
              </div>
              <div class="hero-carousel-controls">
                <button type="button" class="carousel-nav" data-carousel-prev>
                  Previous
                </button>
                <div class="carousel-dots" role="tablist" aria-label="Hero image options">
                  {
                    heroSlides.map((slide, index) => (
                      <button
                        type="button"
                        class="carousel-dot"
                        data-carousel-dot={index}
                        aria-label={`Show image ${index + 1}: ${slide.label}`}
                        aria-current={index === 0 ? 'true' : 'false'}
                      ></button>
                    ))
                  }
                </div>
                <button type="button" class="carousel-nav" data-carousel-next>
                  Next
                </button>
              </div>
            </div>
          </figure>

          <div>
            <span class="muted-chip">Baseline concept</span>
            <h1 id="overview-title">Design Judgment Kit</h1>
            <p class="subhead">
              Two practical tools for AI-accelerated product teams: a responsibilities matrix and a
              decision-rights snapshot.
            </p>
            <div class="cta-row">
              <a class="button primary" href="#matrix">Open the matrix</a>
              <a class="button ghost" href="#downloads">Open downloads</a>
            </div>
            <p class="small-note">Local review route. No deployment changes.</p>
          </div>

          <div>
            <p>
              AI output can look “finished” before teams align on tradeoffs.
            </p>
            <p>
              This baseline keeps the original structure but reframes the site around operational kit usage
              instead of visual style guidance.
            </p>
          </div>
        </div>
      </section>

      <section id="kit-modules" aria-labelledby="kit-modules-title">
        <h2 id="kit-modules-title">Kit modules</h2>
        <p class="intro">Use these modules together to move from draft speed to durable decision quality.</p>
        <div class="kit-modules">
          {
            kitModules.map((module) => (
              <article class="module-card">
                <strong>{module.title}</strong>
                <p>{module.summary}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="divider" aria-label="Supporting divider illustration">
        <img
          class="divider-image"
          src="/assets/support_draft_vs_default_header_1536x804.png"
          alt="Soft fog separates early drafts from committed decisions."
          width="1536"
          height="804"
          loading="lazy"
          decoding="async"
        />
      </section>

      <section id="matrix" aria-labelledby="matrix-title">
        <h2 id="matrix-title">Responsibilities matrix</h2>
        <p class="intro">A practical view of what the designer owns, protects, and checks week to week.</p>

        <div class="matrix-controls">
          <label class="sr-only" for="matrix-search">Search responsibilities</label>
          <input
            id="matrix-search"
            type="search"
            placeholder="Search responsibilities by keyword"
            autocomplete="off"
            data-matrix-search
          />
          <button type="button" data-matrix-clear>Clear</button>
          <p class="result-count" aria-live="polite" data-matrix-count>
            Showing {matrix.length} of {matrix.length}
          </p>
        </div>

        <div class="panel matrix-desktop">
          <div class="table-wrap">
            <table class="data-table" aria-describedby="matrix-title">
              <thead>
                <tr>
                  <th scope="col">Area</th>
                  <th scope="col">What you own</th>
                  <th scope="col">Week to week</th>
                  <th scope="col">Guardrails</th>
                  <th scope="col">Warning signs</th>
                </tr>
              </thead>
              <tbody>
                {
                  matrix.map((item) => (
                    <tr data-matrix-row data-search={item.search}>
                      <th scope="row">{item.area}</th>
                      <td>{item.own}</td>
                      <td>{item.weekToWeek}</td>
                      <td>{item.guardrails}</td>
                      <td>{item.warning}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
          <p class="helper">Use this as a diagnostic, not a policy document.</p>
        </div>

        <div class="matrix-mobile" aria-label="Responsibilities in card form">
          {
            matrix.map((item) => (
              <details class="matrix-card" data-matrix-card data-search={item.search}>
                <summary>
                  <strong>{item.area}</strong>
                  <span>{item.own}</span>
                </summary>
                <div class="matrix-card-body">
                  <p>
                    <strong>Week to week:</strong> {item.weekToWeek}
                  </p>
                  <p>
                    <strong>Guardrails:</strong> {item.guardrails}
                  </p>
                  <p>
                    <strong>Warning signs:</strong> {item.warning}
                  </p>
                </div>
              </details>
            ))
          }
          <p class="helper">Use this as a diagnostic, not a policy document.</p>
        </div>
      </section>

      <section id="decision-rights" aria-labelledby="decision-rights-title">
        <h2 id="decision-rights-title">Decision-rights snapshot (RACI-style)</h2>
        <p class="context">
          This reduces ambiguity when drafts move fast and look complete before tradeoffs are named.
        </p>

        <div class="panel raci-desktop">
          <div class="table-wrap">
            <table class="data-table" aria-describedby="decision-rights-title">
              <thead>
                <tr>
                  <th scope="col">Decision type</th>
                  <th scope="col">Designer</th>
                  <th scope="col">PM</th>
                  <th scope="col">Engineering</th>
                </tr>
              </thead>
              <tbody>
                {
                  raci.map((row) => (
                    <tr>
                      <th scope="row">{row.decisionType}</th>
                      <td>{row.designer}</td>
                      <td>{row.pm}</td>
                      <td>{row.engineering}</td>
                    </tr>
                  ))
                }
              </tbody>
            </table>
          </div>
        </div>

        <div class="raci-mobile" aria-label="Decision rights in card form">
          {
            raci.map((row) => (
              <article class="raci-card">
                <h3>{row.decisionType}</h3>
                <dl>
                  <dt>Designer</dt>
                  <dd>{row.designer}</dd>
                  <dt>PM</dt>
                  <dd>{row.pm}</dd>
                  <dt>Engineering</dt>
                  <dd>{row.engineering}</dd>
                </dl>
              </article>
            ))
          }
        </div>
      </section>

      <section id="how-to-use" aria-labelledby="how-to-use-title">
        <h2 id="how-to-use-title">How to use this kit</h2>
        <ol>
          {
            howToUseSteps.map((step) => (
              <li>{step}</li>
            ))
          }
        </ol>

        <aside class="callout" aria-label="Common failure modes">
          <h3>Common failure modes</h3>
          <ul>
            {
              failureModes.map((failure) => (
                <li>{failure}</li>
              ))
            }
          </ul>
        </aside>
      </section>

      <section id="downloads" aria-labelledby="downloads-title">
        <h2 id="downloads-title">Downloads</h2>
        <div class="downloads-row">
          <a class="button ghost" href="#downloads" aria-disabled="true" title="PDF coming soon">
            Matrix + RACI (PDF)
          </a>
          <a class="button" href="/downloads/matrix.csv" download>
            Matrix (CSV)
          </a>
          <a class="button" href="/downloads/raci.csv" download>
            RACI (CSV)
          </a>
        </div>
      </section>

      <footer>
        <p>Written by Mike Long.</p>
        <p>Illustrations generated with ChatGPT (OpenAI), art direction: Foggy Bloom Editorial.</p>
        <p>This baseline preserves the original narrative while centering operational kit usage.</p>
      </footer>
    </main>

    <script>
      import { initKitPage } from '../../scripts/init-kit-page';

      initKitPage();
    </script>
  </body>
</html>
