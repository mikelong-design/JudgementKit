---
import SiteLayout from '../components/SiteLayout.astro';
import { getAllKits, orderedModules } from '../lib/kits';
import { SITE } from '../lib/site';

const kits = getAllKits();
const currentKit = kits[0];
const primaryModules = currentKit ? orderedModules(currentKit) : [];

const navLinks = [
  { href: '/#vision', label: 'Vision' },
  { href: '/kits', label: 'Kits' },
  { href: '/#domain-strategy', label: 'Domain Strategy' },
  { href: '/review', label: 'Review Routes' }
];
---

<SiteLayout
  title="Platform"
  description={SITE.description}
  path="/"
  navLinks={navLinks}
  bodyClass="platform-home"
>
  <section class="platform-hero" id="top" aria-labelledby="home-title">
    <div class="hero-copy">
      <span class="muted-chip">Canonical platform: judgmentkit.design</span>
      <h1 id="home-title">Judgment Kit Platform</h1>
      <p class="subhead">
        Judgment Kit is a platform of practical operating kits that help AI-accelerated product teams
        preserve <strong>decision quality</strong>, <strong>accountability</strong>, and
        <strong> product coherence</strong> when output becomes cheap and finished-looking.
      </p>
      <div class="cta-row">
        <a class="button primary" href="/kits">Browse kits</a>
        <a class="button ghost" href={currentKit ? `/kits/${currentKit.slug}` : '/kits'}>Open current kit</a>
      </div>
      <p class="small-note">
        Core thesis: <em>AI accelerates drafts; judgment prevents drafts becoming defaults.</em>
      </p>
      <p>
        The failure mode has changed. Teams do not struggle to generate options; they struggle to keep
        polished drafts from quietly becoming decisions without explicit ownership or tradeoff review.
      </p>
      <p>
        Judgment Kit turns judgment into a repeatable operating system so responsibilities, decision
        rights, and cadence are visible before work hardens.
      </p>
    </div>

    <div class="hero-sidebar">
      <div class="summary-grid">
        <article class="summary-card">
          <strong>Responsibilities are explicit</strong>
          <p>What is owned, protected, and monitored as output accelerates.</p>
        </article>
        <article class="summary-card">
          <strong>Decision rights are explicit</strong>
          <p>Who is accountable before polished drafts harden into default decisions.</p>
        </article>
        <article class="summary-card">
          <strong>Cadence is explicit</strong>
          <p>Judgment shows up as ritual instead of rescue work.</p>
        </article>
      </div>

      <figure class="supporting-image">
        <img
          src="/assets/ownership_visible_v4_header_1536x804.png"
          alt="A small group shares a lantern in fog, lighting a clear path while other lanterns drift unattended."
          width="1536"
          height="804"
          loading="eager"
          decoding="async"
        />
      </figure>
    </div>
  </section>

  <section id="vision" aria-labelledby="vision-title">
    <span class="eyebrow">Vision</span>
    <h2 id="vision-title">Draft speed is no longer the bottleneck</h2>
    <div class="kit-grid">
      <article class="spec-card">
        <strong>Looks complete gets treated as consensus</strong>
        <p>Teams collapse into default decisions because polished drafts arrive before rationale and ownership.</p>
      </article>
      <article class="spec-card">
        <strong>Output volume increases without clear ownership</strong>
        <p>AI expands production capacity faster than teams clarify who protects coherence and quality.</p>
      </article>
      <article class="spec-card">
        <strong>Teams ship polish faster than they ship judgment</strong>
        <p>Operational rituals lag behind generation speed, so mistakes become expensive before they become visible.</p>
      </article>
    </div>
  </section>

  <section aria-labelledby="non-goals-title">
    <span class="eyebrow">Non-goals</span>
    <h2 id="non-goals-title">The platform is not a tool catalog</h2>
    <div class="kit-grid">
      <article class="spec-card">
        <strong>Not a prompt library</strong>
        <p>The kits are built for live delivery work, not prompt collection or vendor comparison.</p>
      </article>
      <article class="spec-card">
        <strong>Not LLM-specific guidance</strong>
        <p>The operating model focuses on judgment and accountability, not model recommendations.</p>
      </article>
      <article class="spec-card">
        <strong>Not design philosophy essays</strong>
        <p>Every page should stay operational, citeable, and useful in active product decisions.</p>
      </article>
    </div>
  </section>

  <section aria-labelledby="kit-contract-title">
    <span class="eyebrow">Kit Contract</span>
    <h2 id="kit-contract-title">What ships in every kit</h2>
    <div class="kit-contract">
      <div class="module-nav-grid">
        {
          primaryModules.map((module) => (
            <article class="module-nav-card">
              <span class="muted-chip">{module.slug}</span>
              <h3>{module.title}</h3>
              <p>{module.summary}</p>
            </article>
          ))
        }
      </div>
      <div class="review-panel">
        <p>Each kit must also ship a short “How to use this kit” runbook and explicit failure modes.</p>
        <p>The flow variant is optional and maps the kit to delivery stages from Frame through Audit.</p>
      </div>
    </div>
  </section>

  <section id="kits" aria-labelledby="current-kits-title">
    <span class="eyebrow">Current Kits</span>
    <h2 id="current-kits-title">Citeable kits and modules</h2>
    <div class="current-kits-grid">
      {
        kits.map((kit) => (
          <article class="kit-card">
            <span class="muted-chip">{kit.audience}</span>
            <h3>{kit.title}</h3>
            <p>{kit.subtitle}</p>
            <p>
              <strong>Thesis:</strong> {kit.coreThesis}
            </p>
            <div class="cta-row">
              <a class="button primary" href={`/kits/${kit.slug}`}>Open kit</a>
              <a class="button ghost" href={`/kits/${kit.slug}/${kit.modules[0]?.slug}`}>Open first module</a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section id="domain-strategy" aria-labelledby="domain-title">
    <span class="eyebrow">Domain Strategy</span>
    <h2 id="domain-title">One canonical domain, two redirect-only catchers</h2>
    <div class="domain-grid">
      <figure class="domain-diagram">
        <img
          src="/diagrams/domain-strategy-platform.svg"
          alt="Domain strategy flow showing judgmentkit.design as canonical and .com domains redirecting in one hop."
          width="980"
          height="540"
          loading="lazy"
          decoding="async"
        />
      </figure>
      <div class="domain-rules">
        <article class="domain-rule">
          <strong>Canonical</strong>
          <p>`judgmentkit.design` serves all HTML, metadata, and sitemap references.</p>
        </article>
        <article class="domain-rule">
          <strong>Redirect-only catchers</strong>
          <p>`judgmentkit.com` and `judgementkit.com` permanently redirect to the matching canonical path.</p>
        </article>
        <article class="domain-rule">
          <strong>Normalization</strong>
          <p>`www` redirects to apex and Vercel handles HTTP to HTTPS, preserving path and query.</p>
        </article>
      </div>
    </div>
  </section>

  <section aria-labelledby="ia-title">
    <span class="eyebrow">Information Architecture</span>
    <h2 id="ia-title">Platform pages are organized for citation</h2>
    <div class="ia-grid">
      <article class="ia-card">
        <strong>/kits</strong>
        <p>Kit library index.</p>
      </article>
      <article class="ia-card">
        <strong>/kits/&lt;kit-slug&gt;</strong>
        <p>Kit landing page with modules, runbook, failure modes, and flow view.</p>
      </article>
      <article class="ia-card">
        <strong>/kits/&lt;kit-slug&gt;/&lt;module-slug&gt;</strong>
        <p>Shareable deep links for individual modules like responsibilities, decision rights, and cadence.</p>
      </article>
    </div>
  </section>
</SiteLayout>
