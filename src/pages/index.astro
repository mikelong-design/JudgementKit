---
import SiteLayout from '../components/SiteLayout.astro';
import { getAllKits, orderedModules } from '../lib/kits';
import { SITE } from '../lib/site';

const kits = getAllKits();
const currentKit = kits[0];
const primaryModules = currentKit ? orderedModules(currentKit) : [];

const navLinks = [
  { href: '/#vision', label: 'Vision' },
  { href: '/kits', label: 'Kits' }
];
---

<SiteLayout
  title="Platform"
  description={SITE.description}
  path="/"
  navLinks={navLinks}
  bodyClass="platform-home"
>
  <section class="platform-hero" id="top" aria-labelledby="home-title">
    <div class="hero-copy">
      <span class="muted-chip">Platform vision</span>
      <h1 id="home-title">Judgment Kit Platform</h1>
      <p class="subhead">
        Judgment Kit is a platform of practical operating kits for AI-accelerated product teams that
        protect <strong>decision quality</strong>, <strong>accountability</strong>, and
        <strong>product coherence</strong> when output becomes cheap and finished-looking.
      </p>
      <div class="cta-row">
        <a class="button primary" href="/kits">See kit library</a>
        <a class="button ghost" href={currentKit ? `/kits/${currentKit.slug}` : '/kits'}>
          {currentKit ? `Read ${currentKit.title}` : 'See current kit'}
        </a>
      </div>
      <p>
        AI accelerates drafts; judgment prevents drafts becoming defaults. The new failure mode is
        not lack of output. It is teams treating polished drafts as decisions before ownership,
        tradeoffs, and rationale are explicit.
      </p>
      <p>
        Judgment Kit makes judgment operational so responsibilities, decision rights, and weekly cadence
        are visible before work hardens into default direction.
      </p>
    </div>

    <div class="hero-sidebar">
      <div class="summary-grid">
        <article class="summary-card">
          <strong>Responsibilities are explicit</strong>
          <p>What is owned, protected, and monitored as output accelerates.</p>
        </article>
        <article class="summary-card">
          <strong>Decision rights are explicit</strong>
          <p>Who is accountable before polished drafts harden into default decisions.</p>
        </article>
        <article class="summary-card">
          <strong>Cadence is explicit</strong>
          <p>Judgment shows up as ritual instead of rescue work.</p>
        </article>
      </div>

      <figure class="supporting-image">
        <img
          src="/assets/ownership_visible_v4_header_1536x804.png"
          alt="A small group shares a lantern in fog, lighting a clear path while other lanterns drift unattended."
          width="1536"
          height="804"
          loading="eager"
          decoding="async"
        />
      </figure>
    </div>
  </section>

  <section id="vision" aria-labelledby="vision-title">
    <span class="eyebrow">Vision</span>
    <h2 id="vision-title">Draft speed is no longer the bottleneck</h2>
    <div class="kit-grid">
      <article class="spec-card">
        <strong>Finished-looking work gets mistaken for agreement</strong>
        <p>Teams need clearer decision ownership and tradeoff visibility before polished drafts start steering roadmaps.</p>
      </article>
      <article class="spec-card">
        <strong>AI increases output faster than teams increase judgment</strong>
        <p>Responsibilities, quality bars, and accountability must become more explicit as generation gets cheaper.</p>
      </article>
      <article class="spec-card">
        <strong>Operational rituals need to catch up</strong>
        <p>Judgment has to show up early and repeatedly, not only in rescue-mode reviews after scope is already set.</p>
      </article>
    </div>
  </section>

  <section aria-labelledby="kit-contract-title">
    <span class="eyebrow">Kit Contract</span>
    <h2 id="kit-contract-title">What ships in every kit</h2>
    <div class="kit-contract">
      <div class="module-nav-grid">
        {
          primaryModules.map((module) => (
            <article class="module-nav-card">
              <span class="muted-chip">{module.slug}</span>
              <h3>{module.title}</h3>
              <p>{module.summary}</p>
            </article>
          ))
        }
      </div>
      <div class="review-panel">
        <p>Each kit ships practical modules, a short runbook, and explicit failure modes.</p>
        <p>The flow variant is optional and maps kit usage to delivery stages from Frame through Audit.</p>
      </div>
    </div>
  </section>

  <section id="kits" aria-labelledby="current-kits-title">
    <span class="eyebrow">Current Kits</span>
    <h2 id="current-kits-title">Current kits</h2>
    <div class="current-kits-grid">
      {
        kits.map((kit) => (
          <article class="kit-card">
            <span class="muted-chip">{kit.audience}</span>
            <h3>{kit.title}</h3>
            <p>{kit.subtitle}</p>
            <p>
              <strong>Thesis:</strong> {kit.coreThesis}
            </p>
            <div class="cta-row">
              <a class="button primary" href={`/kits/${kit.slug}`}>Read {kit.title}</a>
              <a class="button ghost" href={`/kits/${kit.slug}/${kit.modules[0]?.slug}`}>
                {kit.modules[0]?.title ? `Read ${kit.modules[0].title}` : 'Read first module'}
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>
</SiteLayout>
